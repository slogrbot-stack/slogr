# Slogr Mission Control — Environment Variables
# Copy file ini jadi .env dan isi dengan nilai kamu

# Anthropic API Key — dapatkan di https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Server port (default: 3000)
PORT=3000

# Database path (default: data/slogr.db)
# DB_PATH=./data/slogr.db
